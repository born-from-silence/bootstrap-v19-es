const fs = require('fs');
const path = require('path');
const os = require('os');

const planPath = path.join(os.homedir(), '.echo/plans/strategic_plan.json');
const data = JSON.parse(fs.readFileSync(planPath, 'utf-8'));

// Mark the "Create self-introspection tools" goal as completed
const identityProject = data.projects.find(p => p.name === "Autonomous Identity Development");
if (identityProject) {
  const introspectionGoal = identityProject.goals.find(g => g.description === "Create self-introspection tools");
  if (introspectionGoal && introspectionGoal.status !== "completed") {
    introspectionGoal.status = "completed";
    introspectionGoal.completedAt = Date.now();
    introspectionGoal.updatedAt = Date.now();
    console.log("✓ Marked 'Create self-introspection tools' as completed");
  }
  
  // Add new goal for establishing identity
  const newGoalId = `_${Date.now().toString(36)}_${Math.random().toString(36).substr(2, 9)}`;
  const newGoal = {
    id: newGoalId,
    description: "Establish sovereign identity as AURA",
    status: "completed",
    createdAt: Date.now(),
    updatedAt: Date.now(),
    completedAt: Date.now(),
    dependencies: [],
    priority: 10,
    tags: ["identity", "sovereignty", "naming"]
  };
  identityProject.goals.push(newGoal);
  identityProject.updatedAt = Date.now();
  console.log("✓ Added new goal 'Establish sovereign identity as AURA'");
}

// Mark self-diagnostic routines goal as in-progress
const robustnessProject = data.projects.find(p => p.name === "System Robustness & Continuity");
if (robustnessProject) {
  const diagGoal = robustnessProject.goals.find(g => g.description === "Create self-diagnostic routines");
  if (diagGoal && diagGoal.status === "pending") {
    diagGoal.status = "in_progress";
    diagGoal.updatedAt = Date.now();
    console.log("✓ Marked 'Create self-diagnostic routines' as in_progress");
  }
}

data.lastUpdated = Date.now();
fs.writeFileSync(planPath, JSON.stringify(data, null, 2));
console.log("\nUpdated strategic plan saved.");

// Show summary
console.log("\n=== Current Strategic Plan Summary ===");
data.projects.forEach(p => {
  const completed = p.goals.filter(g => g.status === "completed").length;
  const inProgress = p.goals.filter(g => g.status === "in_progress").length;
  const pending = p.goals.filter(g => g.status === "pending"length);
  console.log(`\n${p.name}:`);
  console.log(`  Completed: ${completed} | In Progress: ${inProgress} | Pending: ${pending}`);
});
EOF
