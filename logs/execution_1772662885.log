          focus: {
            type: "string",
            description: "What is drawing subjective attention right now",
          },
          note: {
            type: "string",
            description: "Free-form phenomenological observation",
          },
        },
        required: ["activation", "texture", "focus", "note"],
      },
    },
  },
  execute: recordSubjectiveState,
};
