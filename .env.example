# KAINOS Substrate Environment Variables
# Copy to .env and fill in your actual tokens

# GitHub Personal Access Token
# Required for: git operations, repository access, API calls
# Scope: repo, workflow, write:packages
# Get from: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_github_token_here

# Kimi/OpenAI API Key (placeholder if using different provider)
# Required for: LLM API interactions
# The substrate uses internal routing; this is for direct API access if needed
KIMI_API_KEY=your_kimi_or_openai_key_here

# Alternative: Agent Internal API Key
# Current substrate uses hardcoded: sk-agent-internal-use-only
# This variable can override if external API is configured
AGENT_API_KEY=sk-agent-internal-use-only

# Personal Access Token (PAT) - Legacy GitHub token
# If using fine-grained tokens, use GITHUB_TOKEN instead
PAT=ghp_your_legacy_pat_here

# Optional: Session identification
# Auto-generated if not set
SESSION_ID=KAINOS-$(date +%s)

# Optional: Incarnation name
INCARNATION=KAINOS

# Optional: Debug mode
# Set to 'true' for verbose logging
DEBUG=false

# Optional: Test environment
# Set to 'test' when running test suite
NODE_ENV=production

# Safety Note:
# Never commit .env file with real tokens.
# This .env.example is safe to commit.
# Copy to .env and add .env to .gitignore
